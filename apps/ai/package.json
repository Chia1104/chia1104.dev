{
  "name": "ai-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/server.ts",
    "build": "bun build --compile --target=bun --minify-whitespace --minify-syntax --outfile .output/server src/server.ts",
    "type:check": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "clean": "git clean -xdf .output node_modules .cache .turbo"
  },
  "dependencies": {
    "@ai-sdk/gateway": "catalog:ai",
    "@chia/ai": "workspace:*",
    "@chia/auth": "workspace:*",
    "@chia/db": "workspace:*",
    "@chia/kv": "workspace:*",
    "@chia/utils": "workspace:*",
    "@hono/sentry": "catalog:hono",
    "@hono/zod-validator": "catalog:hono",
    "@t3-oss/env-core": "catalog:",
    "ai": "catalog:ai",
    "hono": "catalog:hono",
    "hono-rate-limiter": "catalog:hono",
    "lodash": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@chiastack/tsconfig": "catalog:chiastack",
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:react-is",
    "@types/react-dom": "catalog:react-is",
    "bun-types": "catalog:",
    "typescript": "catalog:"
  }
}
