PORT=3008
NODE_ENV=development
ENV=development

# shared secret for /workflow/internal/* (must match apps/service)
INTERNAL_WORKFLOW_SERVICE_TOKEN=

# workflow world — owned exclusively by this service
WORKFLOW_TARGET_WORLD=@workflow/world-postgres
WORKFLOW_POSTGRES_URL=
WORKFLOW_REDIS_URI=
REDIS_URI=redis://localhost:6380

DATABASE_URL=
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/postgres
BETA_DATABASE_URL=

ALGOLIA_APPLICATION_ID=
ALGOLIA_API_KEY=
ALGOLIA_FEEDS_INDEX_NAME=

# embedding generation (minimal set — no AI_AUTH_* signing keys)
OPENAI_API_KEY=
AI_GATEWAY_API_KEY=
OLLAMA_BASE_URL=

SENTRY_DSN=
