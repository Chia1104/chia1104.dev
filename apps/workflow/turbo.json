{
  "$schema": "https://turbo.build/schema.json",
  "tags": ["workflow"],
  "extends": ["//", "@chia/ai", "@chia/api", "@chia/db", "@chia/utils"],
  "tasks": {
    "build": {
      "outputs": [".output/**", "!.output/server/node_modules/**"],
      "env": [
        "WORKFLOW_TARGET_WORLD",
        "WORKFLOW_POSTGRES_URL",
        "WORKFLOW_REDIS_URI",
        "REDIS_URI",
        "SENTRY_DSN",
        "ZEABUR_SERVICE_ID",
        "TIMEOUT_MS",
        "OPENAI_API_KEY",
        "AI_GATEWAY_API_KEY",
        "OLLAMA_BASE_URL",
        "INTERNAL_WORKFLOW_SERVICE_TOKEN"
      ],
      "passThroughEnv": [
        "WORKFLOW_TARGET_WORLD",
        "WORKFLOW_POSTGRES_URL",
        "WORKFLOW_REDIS_URI",
        "REDIS_URI",
        "SENTRY_DSN",
        "ZEABUR_SERVICE_ID",
        "TIMEOUT_MS",
        "OPENAI_API_KEY",
        "AI_GATEWAY_API_KEY",
        "OLLAMA_BASE_URL",
        "INTERNAL_WORKFLOW_SERVICE_TOKEN"
      ]
    }
  }
}
