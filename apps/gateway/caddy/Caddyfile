# Edge gateway: routes public traffic to the auth service and the legacy
# service, authenticating API requests at the edge via forward_auth.
#
# Keep in sync with ../routes.config.ts — the local dev proxy mirrors this
# routing table.
#
# Required environment variables (see README.md):
#   PORT                         injected by Railway
#   AUTH_UPSTREAM                e.g. auth.railway.internal:3006
#   SERVICE_UPSTREAM             e.g. service.railway.internal:3005
#   INTERNAL_AUTH_SERVICE_TOKEN  shared secret for /auth/internal/*

{
	admin off
	auto_https off
	persist_config off
}

:{$PORT} {
	log

	# Identity headers are injected by forward_auth below — strip anything
	# the client sent so they can never be spoofed.
	request_header -x-ch-auth-session
	request_header -x-ch-auth-api-key

	# Server-to-server routes must never be reachable from the public edge.
	handle /auth/internal/* {
		respond 404
	}

	# better-auth flows: sign-in, OAuth callbacks, get-session, ...
	handle /auth/* {
		reverse_proxy {$AUTH_UPSTREAM}
	}

	# Legacy auth path — rewrite onto the auth service until every client
	# points at /auth directly, then remove this block.
	handle /api/v1/auth/* {
		uri replace /api/v1/auth /auth
		reverse_proxy {$AUTH_UPSTREAM}
	}

	# Main API: authenticate at the edge, then hand off with identity
	# headers. mode=optional lets anonymous requests through so public
	# endpoints keep working — the service guards remain the enforcement
	# point, but they trust the injected identity instead of re-verifying.
	#
	# To hard-block anonymous traffic for a prefix, add a more specific
	# handle above this one using `uri /auth/internal/gate` (mode defaults
	# to required, which answers 401 when unauthenticated).
	handle /api/v1/* {
		forward_auth {$AUTH_UPSTREAM} {
			uri /auth/internal/gate?mode=optional
			header_up x-ch-internal-token {$INTERNAL_AUTH_SERVICE_TOKEN}
			copy_headers x-ch-auth-session x-ch-auth-api-key
		}
		reverse_proxy {$SERVICE_UPSTREAM}
	}

	handle {
		respond 404
	}
}
