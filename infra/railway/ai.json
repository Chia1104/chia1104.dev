{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": [
      "/apps/ai",
      "/packages/ai",
      "/packages/auth",
      "/packages/db",
      "/packages/kv",
      "/packages/utils",
      "/infra/railway/ai.json",
      "package.json",
      "turbo.json"
    ],
    "dockerfilePath": "apps/ai/Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
